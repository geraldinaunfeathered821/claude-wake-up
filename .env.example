# 1. Search @BotFather on Telegram → /newbot → get token
TELEGRAM_BOT_TOKEN=your-token-here

# 2. Send /start to @userinfobot on Telegram → get your user ID
#    Multiple users: comma-separated (e.g. 123456789,987654321)
TELEGRAM_ALLOWED_USERS=123456789

# 3. Zellij session name (required — auto-created if not running)
ZELLIJ_TARGET_SESSION=main

# 4. Skip Claude permission prompts? (true/false)
#    true  = Claude runs with --dangerously-skip-permissions (fully autonomous, no tool confirmations)
#    false = Claude runs normally (asks for permission on risky actions)
#    ⚠️  When enabled, Claude can execute ANY shell command, edit ANY file, and make network
#       requests without asking. Only enable this on machines you fully control.
DANGEROUSLY_SKIP_PERMISSIONS=false
